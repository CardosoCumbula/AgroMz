# ------------------------------------------------------------------------------
# AgroMoz - Moçambique
# PRODUCTION ENVIRONMENT CONFIGURATION 
# ------------------------------------------------------------------------------
#
# IMPORTANT: This application now operates in STRICT PRODUCTION MODE.
# Fallbacks and simulators have been disabled. You must provide valid 
# Supabase credentials and M-Pesa keys for the application to function.
# 
# ------------------------------------------------------------------------------

# [1] SUPABASE CONNECTION
# Create your project at https://supabase.com
# Run the SQL script located in `supabase/schema.sql` to initialize your database.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# [2] TRANSACTIONAL EMAIL PROVIDER (Resend)
# Required for sending OTP verification codes and Order Confirmations.
# Create an account at https://resend.com
RESEND_API_KEY="re_your_api_key_here"

# [3] M-PESA GATEWAY CONFIGURATION
# Set to 'production' to use real money endpoints, or 'sandbox' for testing.
MPESA_ENVIRONMENT="production"

# ---> OPTION A: VODACOM MOZAMBIQUE API (Primary)
# Get keys from https://developer.mpesa.vm.co.mz/
MPESA_API_KEY="your_vodacom_api_key"
MPESA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIICIjANBgkqhkiG9w0BAQE...\n-----END PUBLIC KEY-----"
MPESA_SERVICE_PROVIDER_CODE="171717"

# ---> OPTION B: SAFARICOM DARAJA KENYA API (Secondary/Fallback)
# Get keys from https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY="your_daraja_consumer_key"
MPESA_CONSUMER_SECRET="your_daraja_consumer_secret"
MPESA_SHORTCODE="174379"
MPESA_PASSKEY="your_daraja_passkey"

# The callback URL where M-Pesa will send the payment status webhook.
# Must be publicly accessible (e.g., https://your-domain.com/api/mpesa-callback)
MPESA_CALLBACK_URL="https://your-production-domain.mz/api/mpesa-callback"
APP_URL="https://your-production-domain.mz"
